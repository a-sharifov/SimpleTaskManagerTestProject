@model Domain.SharedKernel.Paginations.PagedList<Domain.TaskModelAggregate.Projections.TaskModelSummary>

@{
    ViewData["Title"] = "Tasks";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Tasks</h1>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> New Task
    </a>
</div>

<form method="get" asp-action="Index" class="mb-3">
    <div class="row g-2 align-items-end">
        <div class="col-auto">
            <label for="orderBy" class="form-label mb-0">Order by</label>
            <select name="orderBy" id="orderBy" class="form-select" onchange="this.form.submit()">
                @foreach (var token in (IEnumerable<string>)ViewBag.OrderByTokens)
                {
                    <option value="@token" selected="@(token == (string)ViewBag.CurrentOrderBy)">@token</option>
                }
            </select>
        </div>
        <input type="hidden" name="pageSize" value="@Model.PageSize" />
    </div>
</form>

@if (!Model.Items.Any())
{
    <div class="alert alert-info">No tasks found. Create your first task!</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Title</th>
                    <th>Priority</th>
                    <th>Deadline</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td style="max-width: 300px;">
                            <a asp-action="Details" asp-route-id="@item.Id"
                               class="d-inline-block text-truncate" style="max-width: 100%;"
                               title="@item.Title">@item.Title</a>
                        </td>
                        <td>
                            @{
                                var priorityBadge = item.Priority switch
                                {
                                    "High" => "bg-danger",
                                    "Medium" => "bg-warning text-dark",
                                    _ => "bg-secondary"
                                };
                            }
                            <span class="badge @priorityBadge">@item.Priority</span>
                        </td>
                        <td>@item.Deadline.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            @{
                                var statusBadge = item.Status switch
                                {
                                    "Done" => "bg-success",
                                    "Overdue" => "bg-danger",
                                    "Urgent" => "bg-warning text-dark",
                                    _ => "bg-info text-dark"
                                };
                            }
                            <span class="badge @statusBadge">@item.Status</span>
                        </td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-primary">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-pageNumber="@(Model.CurrentPage - 1)"
                   asp-route-pageSize="@Model.PageSize"
                   asp-route-orderBy="@ViewBag.CurrentOrderBy">
                    &laquo; Previous
                </a>
            </li>

            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-pageNumber="@i"
                       asp-route-pageSize="@Model.PageSize"
                       asp-route-orderBy="@ViewBag.CurrentOrderBy">
                        @i
                    </a>
                </li>
            }

            <li class="page-item @(Model.HasNext ? "" : "disabled")">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-pageNumber="@(Model.CurrentPage + 1)"
                   asp-route-pageSize="@Model.PageSize"
                   asp-route-orderBy="@ViewBag.CurrentOrderBy">
                    Next &raquo;
                </a>
            </li>
        </ul>
    </nav>

    <p class="text-muted text-center">
        Page @Model.CurrentPage of @Model.TotalPages (@Model.TotalCount total tasks)
    </p>
}
